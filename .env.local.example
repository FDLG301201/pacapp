# Supabase — copy this file to .env.local and fill in your values
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google OAuth — configure in Supabase dashboard > Auth > Providers > Google
# (no env vars needed here; handled entirely in Supabase dashboard)

# Resend — for transactional emails (Phase 5)
RESEND_API_KEY=
RESEND_FROM_EMAIL=PACAPP <notificaciones@pacapp.do>

# App URL — used in email links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Maps — for map page (Phase 4)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
